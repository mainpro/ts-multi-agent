# LLM API Configuration
# Choose one provider by setting the corresponding API key

# Alternative: Zhipu AI API (GLM-4.7-flash)
# Get your key from https://open.bigmodel.cn
ZHIPU_API_KEY=

# Alternative: haier
# Get your key from https://modelapi-test.haier.net/model/v1/
# HAIER_API_KEY=apikey-695e38f3e4b0ef43c98f1beb
# LLM_PROVIDER=haier
# LLM_MODEL=glm-5-fp8
# LLM_BASE_URL=https://modelapi-test.haier.net/model/v1/

# Alternative: siliconflow
# Get your key from https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=

LLM_PROVIDER=siliconflow
LLM_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
LLM_BASE_URL=https://api.siliconflow.cn/v1/

# Server port (default: 3000)
PORT=3000
# Temperature 控制模型输出的随机性（0-1之间）
# 较低值（如0.3）使输出更确定、简洁；较高值（如0.8）使输出更随机、有创意
LLM_TEMPERATURE=0.3
# LLM 最大输出 token 数
LLM_MAX_TOKENS=4096