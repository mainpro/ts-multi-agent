# LLM API Configuration
# Choose one provider by setting the corresponding API key

# OpenRouter (Recommended - qwen/qwen3.6-plus-preview:free)
# Get your key from https://openrouter.ai
OPENROUTER_API_KEY=

# Alternative: NVIDIA API (minimax-m2.5 model)
# Get your key from https://www.nvidia.com/en-us/ai/
NVIDIA_API_KEY=

# Alternative: Zhipu AI API (GLM-4.7-flash)
# Get your key from https://open.bigmodel.cn
ZHIPU_API_KEY=

LLM_PROVIDER=nvidia
LLM_MODEL=z-ai/glm4.7
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
