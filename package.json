{
  "name": "ts-multi-agent",
  "version": "1.0.0",
  "description": "TypeScript multi-agent system with main agent orchestration and sub-agent skill execution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --out-dir dist --clean --target node20 && cp AGENT.md dist/ && cp .env.example dist/.env && cp -r skills dist/ && cp -r public dist/ && cp -r system-skills dist/",
    "dev": "bun run --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": [
    "multi-agent",
    "typescript",
    "llm",
    "agentskills"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "^17.2.4",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.1",
    "multer": "^2.1.1",
    "typescript": "5.3.3",
    "yaml": "^2.9.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "20.10.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
